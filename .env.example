# Injective testnet RPC endpoints (EVM-compatible)
# Reference: https://docs.injective.network/develop/public-endpoints
INJECTIVE_TESTNET_RPC=https://k8s.testnet.json-rpc.injective.network/
INJECTIVE_TESTNET_CHAIN_ID=1439

# Mainnet (do not deploy from here without explicit approval)
INJECTIVE_MAINNET_RPC=https://sentry.tm.injective.network/
INJECTIVE_MAINNET_CHAIN_ID=1

# Deployer key (testnet only - never commit a mainnet key)
DEPLOYER_PRIVATE_KEY=0x

# Mock USDT/USDC addresses on Injective testnet (filled after deployment)
MOCK_USDT_ADDRESS=
MOCK_USDC_ADDRESS=

# Protocol addresses (filled after deployment)
TASK_ESCROW_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=

# Treasury and reward pool (multisig addresses for Phase 1)
PROTOCOL_TREASURY=
COMMUNITY_REWARD_POOL=

# Governance (Phase 1: 2-of-3 team multisig)
GOVERNANCE_ADDRESS=
