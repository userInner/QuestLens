{
  "name": "questlens-protocol",
  "version": "0.1.0",
  "private": true,
  "description": "QuestLens Protocol monorepo: decentralized Physical-World Data Oracle for AI and Web3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' run build",
    "test": "pnpm -r --filter './packages/**' run test",
    "lint": "pnpm -r --filter './packages/**' run lint",
    "contracts:build": "pnpm --filter @questlens/contracts run build",
    "contracts:test": "pnpm --filter @questlens/contracts run test",
    "sdk:build": "pnpm --filter @questlens/sdk run build"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.14.10"
  },
  "packageManager": "pnpm@11.1.3"
}
