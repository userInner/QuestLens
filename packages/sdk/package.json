{
  "name": "@questlens/sdk",
  "version": "0.1.0",
  "description": "QuestLens Protocol TypeScript SDK. Wraps TaskEscrow and ReputationRegistry with typed helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx --test-isolation=none test/client.test.ts",
    "test:integration": "node --test --import tsx --test-isolation=none test/integration.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@questlens/relayer": "workspace:*",
    "@questlens/schemas": "workspace:*",
    "ethers": "^6.13.4"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "@types/node": "^20.14.10"
  }
}
