{
  "name": "@questlens/relayer",
  "version": "0.1.0",
  "private": true,
  "description": "QuestLens Relayer Node: ingests Proofs, runs the verification pipeline, attests verdicts on-chain.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "import": "./dist/pipeline/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx --test-isolation=none test/*.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node --import tsx src/server/main.ts"
  },
  "dependencies": {
    "@questlens/schemas": "workspace:*",
    "ethers": "^6.13.4",
    "fastify": "^5.1.0",
    "@fastify/multipart": "^9.0.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "@types/node": "^20.14.10"
  }
}
